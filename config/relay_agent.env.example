# Relay polling agent config (set one on each laptop)

RELAY_URL="https://script.google.com/macros/s/REPLACE_WITH_DEPLOYMENT_ID/exec"
RELAY_SECRET="replace-with-a-long-random-secret"

# Optional overrides. Leave unset to use this repo's defaults.
# RUNNER_PATH="/ABSOLUTE/PATH/auto_refresh_google_slides/scripts/slides_machine_runner.sh"
# RUNNER_CONFIG="/ABSOLUTE/PATH/auto_refresh_google_slides/config/local.env"

POLL_SECONDS=2
CURL_TIMEOUT_SECONDS=8
LISTEN_TIMEOUT_SECONDS=20
LISTEN_ONCE=0

STATE_DIR="$HOME/.codex-slides-relay"
STATE_FILE="$HOME/.codex-slides-relay/last_event_id-main"

ACTION_FILTER="refresh_slides"
FIRE_ON_STARTUP=0
ACK_ON_FAILURE=1
VERBOSE=1
