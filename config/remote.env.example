# Same keys as local.env.example, but tuned for the second laptop.
SLIDES_SOURCE_URL="https://docs.google.com/presentation/d/REPLACE_WITH_ID/edit?slide=id.p#slide=id.p"

# Optional overrides:
# SLIDES_PRESENT_URL="https://docs.google.com/presentation/d/REPLACE_WITH_ID/present?slide=id.p"
# SLIDES_NOTES_URL="https://docs.google.com/presentation/d/REPLACE_WITH_ID/present?slide=id.p&presenter=true"

CHROME_APP="Google Chrome"
CHROME_PROFILE="Default"
BOUNDS_MODE="auto"
DISPLAY_ASSIGNMENT="slides:extended,notes:desktop"

PRIMARY_BOUNDS="0,25,1920,1080"
NOTES_BOUNDS="1920,25,3840,1080"

FULLSCREEN_PRIMARY=1
FULLSCREEN_NOTES=1
CLOSE_EXISTING_WINDOWS=1
CACHE_BUST=1
AUTO_CAPTURE_FRONT_TAB=1
USE_PRESENTER_NOTES_SHORTCUT=1
LAUNCH_DELAY_SECONDS=1.2
NOTES_PLUS_CLICK_STEPS=7
NOTES_PLUS_METHOD="auto"
NOTES_PLUS_READY_DELAY_SECONDS=1.6
NOTES_PLUS_CLICK_DELAY_SECONDS=0.08
NOTES_PLUS_BUTTON_RIGHT_OFFSET=56
NOTES_PLUS_BUTTON_TOP_OFFSET=164
WINDOW_WAIT_TIMEOUT_SECONDS=25
