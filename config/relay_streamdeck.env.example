# Stream Deck trigger config (controller machine)

# Optional overrides. Leave unset to use this repo's defaults.
# LOCAL_RUNNER="/ABSOLUTE/PATH/auto_refresh_google_slides/scripts/slides_machine_runner.sh"
# LOCAL_CONFIG="/ABSOLUTE/PATH/auto_refresh_google_slides/config/local.env"
RUN_LOCAL=1

RUN_RELAY=1
RELAY_URL="https://script.google.com/macros/s/REPLACE_WITH_DEPLOYMENT_ID/exec"
RELAY_SECRET="replace-with-a-long-random-secret"
ACTION="refresh_slides"
SOURCE_LABEL="streamdeck-main"
CURL_TIMEOUT_SECONDS=8
